{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-notify.sh '🤖 Claude Code finished working'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-notify.sh '📢 Claude Code needs your attention'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude-notify.sh '🎯 Claude Code subagent completed'"
          }
        ]
      }
    ],
    "SessionStart": [],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Plan finalized. Consider running /codex-review for cross-model verification.\"}'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "PATH=\"$HOME/.nvm/versions/node/$(ls $HOME/.nvm/versions/node/ | sort -V | tail -1)/bin:$PATH\" node ~/.claude/plugins/cache/claude-hud/claude-hud/*/dist/index.js"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "codex@openai-codex": true,
    "superpowers@claude-plugins-official": true,
    "sjh-skills@sjh-skills": true,
    "chrome-devtools-mcp@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "sjh-skills": {
      "source": {
        "source": "github",
        "repo": "jiahao-shao1/sjh-skills"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true
}
